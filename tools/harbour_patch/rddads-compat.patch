+
+   /* OpenADS Tier-2 fast-path: route a non-AOF SET FILTER forward bulk scan
+      through the server-side FetchWhere op. One round-trip materialises every
+      matching record number, replacing one round-trip per raw record (the
+      remote-scan bottleneck). See adsSetFilter / adsGoTop / adsSkip in ads1.c. */
+   HB_BOOL    fFwEligible;   /* filter qualifies (valid expr, not index-optimized) */
+   HB_BOOL    fFwProbed;     /* remote applicability already committed */
+   HB_BOOL    fFwActive;     /* recno list primed; forward scan served from it */
+   char *     szFwExpr;      /* stored filter predicate for AdsFetchWhere */
+   HB_ULONG * pFwRecNos;     /* primed matching record numbers (table order) */
+   HB_ULONG   ulFwCount;     /* number of entries in pFwRecNos */
+   HB_ULONG   ulFwPos;       /* index of the NEXT record to serve */
 } ADSAREA;
 
