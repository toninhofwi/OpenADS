    /* reset any pending relations */
    SELF_RESETREL( pArea );
 
@@ -1112,14 +1303,23 @@ static HB_ERRCODE adsSeek( ADSAREAP pArea, HB_BOOL bSoftSeek, PHB_ITEM pKey, HB_
                                pszKey, u16KeyLen, u16KeyType, &u16Found );
       if( u32RetVal == AE_SUCCESS && bSoftSeek && ! u16Found )
       {
