+   HB_BOOL    fFwBatchEof;    /* current batch reached table EOF (no more batches) */
+   char *     szFwExpr;       /* stored filter predicate for AdsFetchWhere */
+   char *     szFwCols;       /* comma list of ALL fields (field order) for the batch */
+   ADSHANDLE  hFwRes;         /* live AdsFetchWhere result-set handle (0 = none) */
+   HB_ULONG   ulFwBatchRows;  /* rows in the current batch */
+   HB_ULONG   ulFwRow;        /* index of the NEXT row in the batch to serve */
+   HB_ULONG   ulFwRecNo;      /* recno of the last applied row (server-cursor sync) */
 } ADSAREA;
 
 typedef ADSAREA * ADSAREAP;

