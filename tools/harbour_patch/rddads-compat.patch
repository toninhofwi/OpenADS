+/* ── OpenADS Tier-2 FetchWhere fast-path ──────────────────────────────────
+ *
+ * A SET FILTER whose predicate the server cannot optimise with an index
+ * (AdsGetAOFOptLevel == NONE) forces the classic rddads scan to walk the
+ * table one record at a time, testing the filter client-side: one network
+ * round-trip per *raw* record — the remote bulk-scan bottleneck.
+ *
+ * When the table is remote and no index is active (natural order), the server
+ * evaluates the predicate and returns matching rows (recno + every field) in
+ * batches (AdsFetchWhere). A forward scan walks those rows from the client row
+ * cache via AdsFetchWhereApplyRow — RecNo()/field reads serve from cache with
+ * NO AdsGotoRecord per match, so the whole scan costs ceil(matches/batch)
+ * round-trips. Any non-forward move (GOTO, GO BOTTOM, backward SKIP, write,
+ * index/filter change) drops the batch, resyncs the real server cursor onto
+ * the last visited record, and resumes the classic client-side filter walk —
+ * which is why, on the first prime, we also clear the server AOF/filter and
+ * let SUPER's local filter block drive the fallback (correct Clipper
+ * semantics).
+ *
+ * Additive and self-contained: no existing ACE export is modified; the
+ * AdsFetchWhere* result-set API lives in the OpenADS engine.
+ */
+
+#ifndef ADS_FW_WANT_RECNO
+#define ADS_FW_WANT_RECNO  0x01
+#endif
+#ifndef ADS_FW_BATCH
+#define ADS_FW_BATCH  64       /* matches fetched per AdsFetchWhere round-trip */
+#endif
+
+/* Close the live batch handle and drop the fast-path scan state. When
+   fSyncCursor is set, first move the real server cursor onto the last applied
+   record so a follow-up classic op (backward skip, write, ...) continues from
+   the right place — the fast path never AdsGotoRecord's, so the server cursor
+   otherwise lags at "past the last examined row". */
+static void hb_adsFwClearBatch( ADSAREAP pArea, HB_BOOL fSyncCursor )
+{
+   if( fSyncCursor && pArea->fFwActive && pArea->ulFwRecNo != 0 )
+      AdsGotoRecord( pArea->hTable, ( UNSIGNED32 ) pArea->ulFwRecNo );
+   if( pArea->hFwRes )
+   {
+      AdsFetchWhereClose( pArea->hFwRes );
+      pArea->hFwRes = 0;
+   }
+   pArea->ulFwBatchRows = 0;
+   pArea->ulFwRow       = 0;
+   pArea->fFwBatchEof   = HB_FALSE;
+   pArea->fFwActive     = HB_FALSE;
+}
+
+/* Invalidate the primed scan and resync the server cursor (back to classic). */
+static void hb_adsFwReset( ADSAREAP pArea )
+{
+   hb_adsFwClearBatch( pArea, HB_TRUE );
+}
+
+/* Fully disable the fast-path for this work area (filter cleared/changed,
+   table closed, or a non-remote probe). No resync — the filter is going away,
+   not continuing. */
+static void hb_adsFwDisable( ADSAREAP pArea )
+{
+   hb_adsFwClearBatch( pArea, HB_FALSE );
+   if( pArea->szFwExpr )
+   {
+      hb_xfree( pArea->szFwExpr );
+      pArea->szFwExpr = NULL;
+   }
+   if( pArea->szFwCols )
+   {
+      hb_xfree( pArea->szFwCols );
+      pArea->szFwCols = NULL;
+   }
+   pArea->fFwEligible = HB_FALSE;
+   pArea->fFwProbed   = HB_FALSE;
+}
+
+/* Build the comma-separated list of ALL field names in field order, so each
+   batch row maps 1:1 onto the table columns and AdsFetchWhereApplyRow can
+   populate the row cache that AdsGetField / AdsGetRecordNum read. */
+static HB_BOOL hb_adsFwBuildCols( ADSAREAP pArea )
+{
+   HB_USHORT uiCount = pArea->area.uiFieldCount, ui;
+   HB_SIZE   nLen = 0;
+   char *    sz;
+   char *    p;
+
+   if( uiCount == 0 )
+      return HB_FALSE;
+
+   for( ui = 0; ui < uiCount; ++ui )
+   {
+      const char * name = ( const char * )
+         hb_dynsymName( ( PHB_DYNS ) pArea->area.lpFields[ ui ].sym );
+      nLen += strlen( name ) + 1;       /* name + separator/terminator */
+   }
+
+   sz = ( char * ) hb_xgrab( nLen + 1 );
+   p  = sz;
+   for( ui = 0; ui < uiCount; ++ui )
+   {
+      const char * name = ( const char * )
+         hb_dynsymName( ( PHB_DYNS ) pArea->area.lpFields[ ui ].sym );
+      HB_SIZE l = strlen( name );
+      if( ui > 0 )
+         *p++ = ',';
+      memcpy( p, name, l );
+      p += l;
+   }
+   *p = '\0';
+   pArea->szFwCols = sz;
+   return HB_TRUE;
+}
+
+/* Position the work area on the EOF phantom (no more matches). Mirrors the
+   not-positioned bookkeeping in adsSkipFilter. */
+static void hb_adsFwSetEof( ADSAREAP pArea )
+{
+   HB_ULONG ulRecCount = 0;
+
+   pArea->area.fEof   = HB_TRUE;
+   pArea->area.fBof   = HB_FALSE;
+   pArea->area.fFound = HB_FALSE;
+   pArea->fPositioned = HB_FALSE;
+   SELF_RECCOUNT( &pArea->area, &ulRecCount );
+   pArea->ulRecNo     = ulRecCount + 1;
+}
+
+/* Fetch the next batch of matches into a fresh result handle. The server scan
+   cursor resumes from where the previous batch left off (the fast path never
+   moves it). Returns HB_FALSE only when AdsFetchWhere itself fails (e.g. a
+   non-remote table); an empty-but-successful result returns HB_TRUE with
+   ulFwBatchRows == 0. */
+static HB_BOOL hb_adsFwFetchBatch( ADSAREAP pArea )
+{
+   ADSHANDLE  hRes    = 0;
+   UNSIGNED32 u32Rows = 0;
+   UNSIGNED16 u16Eof  = 0;
+
+   if( pArea->hFwRes )
+   {
+      AdsFetchWhereClose( pArea->hFwRes );
+      pArea->hFwRes = 0;
+   }
+   if( AdsFetchWhere( pArea->hTable, ( UNSIGNED8 * ) pArea->szFwExpr,
+                      ( UNSIGNED8 * ) pArea->szFwCols, ADS_FW_BATCH,
+                      ADS_FW_WANT_RECNO, &hRes ) != AE_SUCCESS )
+      return HB_FALSE;
+
+   pArea->hFwRes        = hRes;
+   AdsFetchWhereRows( hRes, &u32Rows );
+   AdsFetchWhereEof( hRes, &u16Eof );
+   pArea->ulFwBatchRows = ( HB_ULONG ) u32Rows;
+   pArea->ulFwRow       = 0;
+   pArea->fFwBatchEof   = ( u16Eof != 0 );
+   return HB_TRUE;
+}
+
+/* Advance onto the next matched record, refilling the batch as needed, and
+   load it into the row cache via AdsFetchWhereApplyRow (no AdsGotoRecord).
+   Sets EOF when the matches are exhausted. */
+static HB_ERRCODE hb_adsFwStep( ADSAREAP pArea )
+{
+   UNSIGNED32 u32Rec = 0;
+
+   while( pArea->ulFwRow >= pArea->ulFwBatchRows )
+   {
+      if( pArea->fFwBatchEof )             /* no more batches */
+      {
+         hb_adsFwSetEof( pArea );
+         return HB_SUCCESS;
+      }
+      if( ! hb_adsFwFetchBatch( pArea ) )  /* fetch error → give up the fast path */
+      {
+         hb_adsFwReset( pArea );
+         hb_adsFwSetEof( pArea );
+         return HB_SUCCESS;
+      }
+   }
+
+   AdsFetchWhereRecno( pArea->hFwRes, ( UNSIGNED32 ) pArea->ulFwRow, &u32Rec );
+   if( AdsFetchWhereApplyRow( pArea->hFwRes, ( UNSIGNED32 ) pArea->ulFwRow,
+                              pArea->hTable ) != AE_SUCCESS )
+   {
+      /* Could not serve from cache — fall back to a real positioning move so
+         the result stays correct (one round-trip for this row only). */
+      UNSIGNED32 u32RetVal = AdsGotoRecord( pArea->hTable, u32Rec );
+      if( u32RetVal != AE_SUCCESS )
+      {
+         commonError( pArea, EG_CORRUPTION, ( HB_ERRCODE ) u32RetVal, 0, NULL, EF_CANDEFAULT, NULL );
+         return HB_FAILURE;
+      }
+   }
+   pArea->ulFwRow++;
+   pArea->ulFwRecNo = ( HB_ULONG ) u32Rec;
+   pArea->ulRecNo   = ( HB_ULONG ) u32Rec;
+   hb_adsUpdateAreaFlags( pArea );         /* served from the row cache: 0 RTT */
+   pArea->area.fBof = HB_FALSE;
+
+   if( pArea->area.lpdbRelations )
+      SELF_SYNCCHILDREN( &pArea->area );
+
+   return HB_SUCCESS;
+}
+
+/* Prime the fast path from the top of the table. Returns HB_TRUE with the
+   first batch fetched (fFwActive set), or HB_FALSE when not applicable (local
+   table, active index, or server refusal) — caller uses the classic path. On
+   the first successful prime it commits: clears the server AOF/filter so the
+   classic fallback walks via SUPER's local filter block. */
+static HB_BOOL hb_adsFwPrime( ADSAREAP pArea )
+{
+   if( ! pArea->fFwEligible || pArea->szFwExpr == NULL )
+      return HB_FALSE;
+
+   /* Natural order only — AdsFetchWhere returns records in table order, so an
+      active index would scan out of sequence. */
+   if( pArea->hOrdCurrent != 0 )
+      return HB_FALSE;
+
+   if( pArea->szFwCols == NULL && ! hb_adsFwBuildCols( pArea ) )
+      return HB_FALSE;
+
+   if( AdsGotoTop( pArea->hTable ) != AE_SUCCESS )
+      return HB_FALSE;
+
+   if( pArea->hFwRes )                     /* drop any stale handle before re-prime */
+   {
+      AdsFetchWhereClose( pArea->hFwRes );
+      pArea->hFwRes = 0;
+   }
+   pArea->ulFwBatchRows = 0;
+   pArea->ulFwRow       = 0;
+   pArea->fFwBatchEof   = HB_FALSE;
+   pArea->ulFwRecNo     = 0;
+
+   if( ! hb_adsFwFetchBatch( pArea ) )     /* probe: fails on local / unsupported */
+   {
+      hb_adsFwDisable( pArea );
+      return HB_FALSE;
+   }
+
+   if( ! pArea->fFwProbed )
+   {
+      /* First successful prime: commit. Drop the server AOF/filter so any
+         later non-forward navigation uses SUPER's local filter block. */
+      AdsClearAOF( pArea->hTable );
+      AdsClearFilter( pArea->hTable );
+      pArea->area.dbfi.fOptimized = HB_FALSE;
+      pArea->fFwProbed = HB_TRUE;
+   }
+
+   pArea->fFwActive = HB_TRUE;
+   return HB_TRUE;
+}
