    /* 2001-07-19 15:04, BH
       The following call is a necessary workaround for ace32.dll
       prior to 6.1.  There were bugs where
@@ -990,6 +1162,25 @@ static HB_ERRCODE adsGoTop( ADSAREAP pArea )
 
    HB_TRACE( HB_TR_DEBUG, ( "adsGoTop(%p)", ( void * ) pArea ) );
 
