diff --git a/contrib/rddads/ads1.c b/contrib/rddads/ads1.c
index 4c37b03..f5bc08d 100644
--- a/contrib/rddads/ads1.c
+++ b/contrib/rddads/ads1.c
@@ -432,6 +432,165 @@ static HB_ERRCODE hb_adsUpdateAreaFlags( ADSAREAP pArea )
    return HB_SUCCESS;
 }
 
+/* ── OpenADS Tier-2 FetchWhere fast-path ──────────────────────────────────
+ *
+ * A SET FILTER whose predicate the server cannot optimise with an index
+ * (AdsGetAOFOptLevel == NONE) forces the classic rddads scan to walk the
+ * table one record at a time, testing the filter client-side: one network
+ * round-trip per *raw* record — the remote bulk-scan bottleneck.
+ *
+ * When the table is remote and no index is active (natural order), we let
+ * the server evaluate the predicate and return every matching record number
+ * in a single call (AdsFetchWhere, maxRows = all). A forward scan then walks
+ * that list, AdsGotoRecord-ing the real cursor so RecNo()/field reads stay on
+ * the normal path. Any non-forward move (GOTO, GO BOTTOM, backward SKIP,
+ * write, index/filter change) drops the list and resumes the classic
+ * client-side filter walk — which is why, on the first prime, we also clear
+ * the server AOF/filter and let SUPER's local filter block drive the
+ * fallback (correct Clipper semantics).
+ *
+ * Additive and self-contained: no existing ACE export is modified; the
+ * AdsFetchWhere* result-set API lives in the OpenADS engine.
+ */
+
+#ifndef ADS_FW_WANT_RECNO
+#define ADS_FW_WANT_RECNO  0x01
+#endif
+
+static void hb_adsFwReset( ADSAREAP pArea )
+{
+   /* Drop the primed record-number list, keeping eligibility/expr so a later
+      GO TOP can re-prime. */
+   if( pArea->pFwRecNos )
+      hb_xfree( pArea->pFwRecNos );
+   pArea->pFwRecNos = NULL;
+   pArea->ulFwCount = 0;
+   pArea->ulFwPos   = 0;
+   pArea->fFwActive = HB_FALSE;
+}
+
+static void hb_adsFwDisable( ADSAREAP pArea )
+{
+   /* Fully disable the fast-path for this work area (filter cleared/changed,
+      table closed, or a non-remote probe). */
+   hb_adsFwReset( pArea );
+   if( pArea->szFwExpr )
+      hb_xfree( pArea->szFwExpr );
+   pArea->szFwExpr    = NULL;
+   pArea->fFwEligible = HB_FALSE;
+   pArea->fFwProbed   = HB_FALSE;
+}
+
+/* Position the work area on the EOF phantom (no more matches). Mirrors the
+   not-positioned bookkeeping in adsSkipFilter. */
+static void hb_adsFwSetEof( ADSAREAP pArea )
+{
+   HB_ULONG ulRecCount = 0;
+
+   pArea->area.fEof   = HB_TRUE;
+   pArea->area.fBof   = HB_FALSE;
+   pArea->area.fFound = HB_FALSE;
+   pArea->fPositioned = HB_FALSE;
+   SELF_RECCOUNT( &pArea->area, &ulRecCount );
+   pArea->ulRecNo     = ulRecCount + 1;
+}
+
+/* Move the real cursor onto pFwRecNos[ ulFwPos ] and advance. Sets EOF when
+   the list is exhausted. */
+static HB_ERRCODE hb_adsFwStep( ADSAREAP pArea )
+{
+   UNSIGNED32 u32RetVal;
+
+   if( pArea->ulFwPos >= pArea->ulFwCount )
+   {
+      hb_adsFwSetEof( pArea );
+      return HB_SUCCESS;
+   }
+
+   u32RetVal = AdsGotoRecord( pArea->hTable,
+                              ( UNSIGNED32 ) pArea->pFwRecNos[ pArea->ulFwPos ] );
+   if( u32RetVal != AE_SUCCESS )
+   {
+      commonError( pArea, EG_CORRUPTION, ( HB_ERRCODE ) u32RetVal, 0, NULL, EF_CANDEFAULT, NULL );
+      return HB_FAILURE;
+   }
+   pArea->ulFwPos++;
+   hb_adsUpdateAreaFlags( pArea );
+   pArea->area.fBof = HB_FALSE;
+
+   if( pArea->area.lpdbRelations )
+      SELF_SYNCCHILDREN( &pArea->area );
+
+   return HB_SUCCESS;
+}
+
+/* Materialise every matching record number from the top into pFwRecNos.
+   Returns HB_TRUE on success (list primed, fFwActive set) or HB_FALSE when the
+   fast-path is not applicable (local table, active index, or server refusal),
+   in which case the caller must use the classic path. On the first successful
+   prime it commits: clears the server AOF/filter so the classic fallback walks
+   via SUPER's local filter block. */
+static HB_BOOL hb_adsFwPrime( ADSAREAP pArea )
+{
+   ADSHANDLE  hRes = 0;
+   UNSIGNED32 u32RetVal, u32Rows = 0, i;
+
+   if( ! pArea->fFwEligible || pArea->szFwExpr == NULL )
+      return HB_FALSE;
+
+   /* Natural order only — AdsFetchWhere returns records in table order, so an
+      active index would scan out of sequence. */
+   if( pArea->hOrdCurrent != 0 )
+      return HB_FALSE;
+
+   if( AdsGotoTop( pArea->hTable ) != AE_SUCCESS )
+      return HB_FALSE;
+
+   u32RetVal = AdsFetchWhere( pArea->hTable,
+                              ( UNSIGNED8 * ) pArea->szFwExpr,
+                              NULL,             /* record numbers only, no column data */
+                              0xFFFFFFFFUL,     /* every match in one batch */
+                              ADS_FW_WANT_RECNO,
+                              &hRes );
+   if( u32RetVal != AE_SUCCESS )
+   {
+      /* Local table (AE_FUNCTION_NOT_AVAILABLE) or unsupported predicate —
+         disable and fall back to the classic client-side scan. */
+      hb_adsFwDisable( pArea );
+      return HB_FALSE;
+   }
+
+   if( ! pArea->fFwProbed )
+   {
+      /* First successful prime: commit. Drop the server AOF/filter so any
+         later non-forward navigation uses SUPER's local filter block. */
+      AdsClearAOF( pArea->hTable );
+      AdsClearFilter( pArea->hTable );
+      pArea->area.dbfi.fOptimized = HB_FALSE;
+      pArea->fFwProbed = HB_TRUE;
+   }
+
+   hb_adsFwReset( pArea );
+
+   AdsFetchWhereRows( hRes, &u32Rows );
+   if( u32Rows > 0 )
+   {
+      pArea->pFwRecNos = ( HB_ULONG * ) hb_xgrab( ( HB_SIZE ) u32Rows * sizeof( HB_ULONG ) );
+      for( i = 0; i < u32Rows; ++i )
+      {
+         UNSIGNED32 u32Rec = 0;
+         AdsFetchWhereRecno( hRes, i, &u32Rec );
+         pArea->pFwRecNos[ i ] = ( HB_ULONG ) u32Rec;
+      }
+      pArea->ulFwCount = ( HB_ULONG ) u32Rows;
+   }
+   AdsFetchWhereClose( hRes );
+
+   pArea->ulFwPos   = 0;
+   pArea->fFwActive = HB_TRUE;
+   return HB_TRUE;
+}
