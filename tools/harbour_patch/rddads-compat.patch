+         }
       }
    }
    else
@@ -1142,7 +1152,13 @@ static HB_ERRCODE adsSeek( ADSAREAP pArea, HB_BOOL bSoftSeek, PHB_ITEM pKey, HB_
       #if 0
       HB_ERRCODE errCode = SELF_GOTOP( &pArea->area );
       #endif
-      pArea->area.fBof = HB_FALSE;
+      /* OpenADS rddads-compat: SELF_GOTO(0) on an empty table
