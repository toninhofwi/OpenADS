    ; Legacy MSVC2013-era CRT shims (M8.2). Harbour's msvc64 prebuilt
    ; libs reference these symbols; modern UCRT no longer ships them.
    ; ace64.dll re-exports them under their legacy names so a Harbour
    ; app links cleanly without rebuilding Harbour.
    ;
    ; NOTE: _wfsopen is intentionally NOT exported here. Modern UCRT
    ; provides _wfsopen via api-ms-win-crt-stdio-l1-1-0.dll. Exporting
    ; it from the DLL caused STATUS_ENTRYPOINT_NOT_FOUND (0xC0000139)
    ; at load time: the PE loader resolved the DLL's own internal UCRT
    ; import of _wfsopen to its own export, creating a circular symbol
    ; that couldn't be located. See GitHub issue #N.
    _dclass   = openads_dclass
    _dsign    = openads_dsign
    _getch    = openads_getch
    _kbhit    = openads_kbhit
    _eof      = openads_eof

    ; M(rddads-compat) — extra Ads* entry points needed by Harbour
    ; contrib/rddads. Implemented as stubs in ace_exports.cpp;
    ; promoted here so the contrib links cleanly against ace64.lib.
    AdsClearProgressCallback
    AdsCopyTableContent
    AdsData
    AdsFilterOption
    AdsGetTableConType
    AdsMgGetOpenTables2
    AdsRegisterProgressCallback
    AdsTestLogin
    AdsTestRecLocks
    AdsStudioStart
    AdsStudioStop
    AdsStudioPort
    AdsSetIndexOrder
    AdsSetIndexOrderByHandle

