; OpenADS ODBC driver — exported ODBC entry points (x64, undecorated names).
LIBRARY openads_odbc
EXPORTS
    SQLAllocHandle
    SQLFreeHandle
    SQLFreeStmt
    SQLSetEnvAttr
    SQLSetConnectAttr
    SQLGetConnectAttr
    SQLSetStmtAttr
    SQLGetStmtAttr
    SQLDriverConnect
    SQLConnect
    SQLDisconnect
    SQLExecDirect
    SQLPrepare
    SQLExecute
    SQLNumResultCols
    SQLDescribeCol
    SQLColAttribute
    SQLFetch
    SQLGetData
    SQLRowCount
    SQLMoreResults
    SQLTables
    SQLColumns
    SQLPrimaryKeys
    SQLGetTypeInfo
    SQLGetInfo
    SQLEndTran
    SQLGetDiagRec
