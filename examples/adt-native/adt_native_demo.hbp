# OpenADS — native ADT / ADI / ADM Harbour sample (by glokcode)
#
#   set OPENADS_LIB=C:\path\to\OpenADS\build\default\src\Release
#   hbmk2 adt_native_demo.hbp
#
# Place OpenADS ace64.dll next to the .exe (or first on PATH).

adt_native_demo.prg

-comp=msvc64
-w3
-es2

-lrddads
-L${OPENADS_LIB}
-lace64